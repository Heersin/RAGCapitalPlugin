HOST=0.0.0.0
PORT=8000
HOST_PORT=18000

# Fill these with your OpenAI-compatible API settings when you are ready.
LLM_BASE_URL=https://your-openai-compatible-host/v1
LLM_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=replace-with-your-model-name
LLM_TIMEOUT_SECONDS=60

# Startup ingest behavior
AUTO_INGEST=true
INGEST_DOC_ROOT=sample/plugin
INGEST_REBUILD=false
INGEST_ENABLE_PDF=false

# Set to true when your document set includes PDF manuals that should be indexed.
