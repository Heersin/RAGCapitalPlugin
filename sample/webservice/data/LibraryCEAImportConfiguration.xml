<?xml version="1.0" encoding="UTF-8"?>
<FEMParameters>
    <!-- this parameter defines if we want to import scoping data along with part-->
  <Param name="ImportScope" value="false"/>
  <!-- this parameter defines if we want to use external custom plugin for importing the library data. This is an optional parameter. If not provided then library standard XML importer will be used-->
  <Param name="ImportFormatPluginUrl" value=""/>
   <!-- this parameter defines if we want to use custom library part filtering to filter out specific part , its child and property during library import. This is an optional parameter-->
  <Param name="ImportFilterPluginUrl" value=""/>
    <!-- this parameter defines the mode of import. Valid values are truncate or merge-->
  <Param name="ImportMode" value="truncate"/>
    <!-- this parameter defines if import should overwrite parts which is already existing in system-->
  <Param name="OverwritePart" value="true"/>
   <!-- this parameter defines if import should modify the codes description in case there is a conflict with description with the existing codes-->
  <Param name="DuplicateCodeDesc" value="true"/>
   <!-- this parameter defines the source system CIS user name -->
   <Param name="SourceCISUserName" value="System"/>
    <!-- this parameter defines the source system CIS password -->
  <Param name="SourceCISUserPassword" value="manager"/>
  <!-- this parameter defines the source system CIS IP address -->
  <Param name="SourceCISAddress" value="127.0.0.1"/>
  <!-- this parameter defines the source system CIS port -->
  <Param name="SourceCISPort" value="49901"/>
  <!-- this parameter defines if import should retain the part modified time from the incoming library import file -->
  <Param name="ImportTimeStamp" value="true"/>
  <!-- this parameter defines if import log the part numbers of the parts it has imported -->
  <Param name="LogPartNumber" value="true"/>
  <!-- this parameter defines if we want to import part modification history data along with part-->
  <Param name="ImportModificationHistory" value="false"/>

   <!--  this parameter defines whether the temporary library files, generated in temporary area while importing part libraries, should be retained upon task completion.
       -->
  <Param name="KeepDataFile" value="false"/>

  <!-- If the intended Import should be done in secured mode, please uncomment the following 2 params to set the keystore path and password.  CIS port number may have to be modified if this is enabled.  Please see client properties for details on this.  -->
  <!-- this parameter defines the source system keystore path -->
	<!-- <Param name="KeyStore" value="${capital.home}/config/.keystore"/>  -->
  <!-- this parameter defines the source system keystore password -->
	<!--<Param name="KeyPassword" value="chsreporter"/>   -->
</FEMParameters>

