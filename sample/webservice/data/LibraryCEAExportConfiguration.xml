<?xml version="1.0" encoding="UTF-8"?>
<FEMParameters>
   <!-- this parameter defines if we want to export scoping data along with part-->
  <Param name="ExportScope" value="false"/>
   <!-- this parameter defines if we want to use external custom plugin for exporting the library data. This is an optional parameter. If not provided then library standard XML exporter will be used-->
  <Param name="ExportFormatPluginURL" value=""/>
  <!-- this parameter defines if we want to use custom library part filtering to filter out specific part , its child and property during library export. This is an optional parameter-->
  <Param name="ExportFilterPluginURL" value=""/>
  <!-- this parameter defines the destination system import task name -->
  <Param name="DestinationImportInstanceName" value="CEAIMPORT"/>
  <!-- this parameter defines the destination system CIS IP address -->
  <Param name="DestinationCISAddress" value="127.0.0.1"/>
  <!-- this parameter defines the destination system CIS user name -->
  <Param name="DestinationCISUserName" value="system"/>
  <!-- this parameter defines the destination system CIS password -->
  <Param name="DestinationCISUserPassword" value="manager"/>
  <!-- this parameter defines the destination system CIS port -->
  <Param name="DestinationCISPort" value="49901"/>
  <!-- this parameter defines if we want to export part revision data along with part-->
  <Param name="ExportRevision" value="false"/>
  <!-- this parameter defines if we want to export part modification history data along with part-->
  <Param name="ExportModificationHistory" value="false"/>
  <!-- this parameter defines if we want to export all codes along with parts. Note  if this is set to true all the codes in the system will be always exported in each exchange attempt made by the export task-->
  <Param name="ExportAllCodes" value="false"/>

   <!--  this parameter defines whether the temporary library files, generated in temporary area while exporting part libraries, should be retained upon task completion.
       -->
  <Param name="KeepDataFile" value="false"/>

  <!-- If the intended export should be done in secured mode, please uncomment the following 2 params to set the keystore path and password. CIS port number may have to be modified if this is enabled.  Please see client properties for details on this. -->
  <!-- this parameter defines the destination system keystore path -->
  <!-- <Param name="KeyStore" value="${capital.home}/config/.keystore"/>  -->
  <!-- this parameter defines the destination system keystore password -->
  <!-- <Param name="KeyPassword" value="chsreporter"/>  --> 
</FEMParameters>

