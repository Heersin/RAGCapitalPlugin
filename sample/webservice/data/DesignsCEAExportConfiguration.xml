<?xml version="1.0" encoding="UTF-8"?>
<FEMParameters>
	<!-- this parameter defines the destination system import task name -->
	<Param name="DestinationImportInstanceName" value="CEADESIGNSIMPORT"/>
	
	<!-- this parameter defines the destination system CIS IP address -->
	<Param name="DestinationCISAddress" value="127.0.0.1"/>
	
	<!-- this parameter defines the destination system CIS user name -->
	<Param name="DestinationCISUserName" value="system"/>
	
     <!-- this parameter defines the destination system CIS password -->
	<Param name="DestinationCISUserPassword" value="manager"/>
	
     <!-- this parameter defines the destination system CIS port -->
	<Param name="DestinationCISPort" value="49901"/>
	
	<!--  this parameter defines whether the export of integrator designs should also export its generated wiring or not. If not exported we can generate the wiring information at the target system through wiring synthesis -->
	<Param name="IncludeGeneratedWiring" value="false"/>

	<!--  this parameter defines whether the temporary design zip files, generated in temporary area while exporting designs , should be retained upon task completion.  -->
	<Param name="KeepDataFile" value="false"/>

	<!-- If the intended export should be done in secured mode, please uncomment the following 2 params to set the keystore path and password.  CIS port number may have to be modified if this is enabled.  Please see client properties for details on this. -->
	<!-- this parameter defines the destination system keystore path -->
	<!-- <Param name="KeyStore" value="${capital.home}/config/.keystore"/>  -->
	<!-- this parameter defines the destination system keystore password -->
	<!-- <Param name="KeyPassword" value="chsreporter"/>  --> 
	
	
	
<!--  User can filter out designs to export by specifying design export level filters. User can specify project name filter to export only the projects user is interested in. Within project name filter 
We can also specify the specific designs we are interested by design name filter (say export only design with name Design1 ) and also control export of specific design types to export using design type filter ( say export only logical designs) .  Apart from project level filter user can specify design type filter outside of any  ProjectToExport tag. This is a global setting and any other projects which are not specified in ProjectToExport tag will 
be controlled through those Global design type filters.  In case we specify a ProjectToExport filter without any deign name and design type filter then that project will be excluded in export -->
	
 <ExportFilterGroup>
	<!-- For project P1 do export all Logical designs and all versions of a specific design, e.g. an Integrator Plane "IntDesName".  -->
	<ProjectToExport name="P1" >
		<Design name="IntDesName"/>
		<DesignType type="Logical"/>
	</ProjectToExport>
	
	<!-- For project P2 do export only all Harness designs.  -->
	<ProjectToExport name="P2" >
		<DesignType type="Harness"/>
	</ProjectToExport>
	
	<!-- For project P3 do export only all designs from design folder path start with Folder1\Floder2. -->
	<ProjectToExport name="P3" >
		<FolderPath name="Folder1\Folder2"/>
	</ProjectToExport>
	
	<!-- For project P-Restricted do not export any design -->
		<ProjectToExport name="P-Restricted" />
		
	<!-- For project P-All do export all design types -->
	<ProjectToExport name="P-All" >
		<DesignType type="Logical"/>
		<DesignType type="Integrator"/>
		<DesignType type="Harness"/>
		<DesignType type="Topology"/>
		<DesignType type="Functions"/>
		<DesignType type="Platforms"/>
	</ProjectToExport>

<!-- Global setting: For all other projects do export all design types or just specific types, define using DesignType.
	  Logical 		-> Logic Design.
	  Integrator 	-> Integrator Design.
	  Harness 		-> Harness Design.
	  Topology 		-> Topology Design.
	  Functions 	-> Functional Design.
	  Platforms 	-> Platform Design.
	  -->
	<DesignType type="Logical"/>
	<DesignType type="Integrator"/>
	<DesignType type="Harness"/>
	<DesignType type="Topology"/>
	<DesignType type="Functions"/>
	<DesignType type="Platforms"/>
<!-- Global setting: In case for all other projects no export should happen, just leave the global section blank -->

</ExportFilterGroup>

</FEMParameters>

